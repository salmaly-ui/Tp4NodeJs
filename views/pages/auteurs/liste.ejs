<%- include('../../partials/header') %>
<%- include('../../partials/navigation') %>

<div class="container">

  <h1>Liste des Auteurs</h1>

  <a href="/auteurs/ajouter" class="btn btn-primary">
    + Ajouter un auteur
  </a>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Nom</th>
          <th>Prénom</th>
          <th>Email</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        <% auteurs.forEach(a => { %>
        <tr>
          <td><%= a.id %></td>
          <td><%= a.nom %></td>
          <td><%= a.prenom %></td>
          <td><%= a.email %></td>

          <td>
            <a class="btn btn-view" href="/auteurs/<%= a.id %>">Voir</a>
            <a class="btn btn-edit" href="/auteurs/<%= a.id %>/modifier">Modifier</a>

            <form action="/auteurs/<%= a.id %>/supprimer" method="POST" style="display:inline;">
              <button class="btn btn-delete"
                onclick="return confirm('Supprimer cet auteur ?')">
                Supprimer
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

  </div>
</div>

<%- include('../../partials/footer') %>